<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controller.LoginController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterController</servlet-name>
        <servlet-class>controller.RegisterController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controller.LogoutController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardAdminController</servlet-name>
        <servlet-class>controller.DashboardAdminController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardTeacherController</servlet-name>
        <servlet-class>controller.DashboardTeacherController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProfileTeacherController</servlet-name>
        <servlet-class>controller.ProfileTeacherController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardStudentController</servlet-name>
        <servlet-class>controller.DashboardStudentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProfileStudentController</servlet-name>
        <servlet-class>controller.ProfileStudentController</servlet-class>
    </servlet>
    
    <!-- New Controllers -->
    <servlet>
        <servlet-name>CourseController</servlet-name>
        <servlet-class>controller.CourseController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ClassController</servlet-name>
        <servlet-class>controller.ClassController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EnrollmentController</servlet-name>
        <servlet-class>controller.EnrollmentController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>MaterialController</servlet-name>
        <servlet-class>controller.MaterialController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AssignmentController</servlet-name>
        <servlet-class>controller.AssignmentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SubmissionController</servlet-name>
        <servlet-class>controller.SubmissionController</servlet-class>
    </servlet>
    
    <!-- Phase 3 Controllers -->
    <servlet>
        <servlet-name>NotificationController</servlet-name>
        <servlet-class>controller.NotificationController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PaymentController</servlet-name>
        <servlet-class>controller.PaymentController</servlet-class>
    </servlet>
    
    <!-- Additional Controllers -->
    <servlet>
        <servlet-name>StudentController</servlet-name>
        <servlet-class>controller.StudentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TeacherController</servlet-name>
        <servlet-class>controller.TeacherController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MockTestController</servlet-name>
        <servlet-class>controller.MockTestController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LeadController</servlet-name>
        <servlet-class>controller.LeadController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TestResultController</servlet-name>
        <servlet-class>controller.TestResultController</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/Login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterController</servlet-name>
        <url-pattern>/Register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/Logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardAdminController</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardTeacherController</servlet-name>
        <url-pattern>/teacher/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardStudentController</servlet-name>
        <url-pattern>/student/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProfileTeacherController</servlet-name>
        <url-pattern>/teacher/profile</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProfileStudentController</servlet-name>
        <url-pattern>/student/profile</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>CourseController</servlet-name>
        <url-pattern>/course</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ClassController</servlet-name>
        <url-pattern>/class</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EnrollmentController</servlet-name>
        <url-pattern>/enrollment</url-pattern>
    </servlet-mapping>
    
    <!-- Phase 2 Controller Mappings -->
    <servlet-mapping>
        <servlet-name>MaterialController</servlet-name>
        <url-pattern>/material</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AssignmentController</servlet-name>
        <url-pattern>/assignment</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SubmissionController</servlet-name>
        <url-pattern>/submission</url-pattern>
    </servlet-mapping>
    
    <!-- Phase 3 Controller Mappings -->
    <servlet-mapping>
        <servlet-name>NotificationController</servlet-name>
        <url-pattern>/notification</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PaymentController</servlet-name>
        <url-pattern>/payment</url-pattern>
    </servlet-mapping>
    
    <!-- Additional Controller Mappings -->
    <servlet-mapping>
        <servlet-name>StudentController</servlet-name>
        <url-pattern>/student</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TeacherController</servlet-name>
        <url-pattern>/teacher</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MockTestController</servlet-name>
        <url-pattern>/mocktest</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LeadController</servlet-name>
        <url-pattern>/lead</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TestResultController</servlet-name>
        <url-pattern>/testresult</url-pattern>
    </servlet-mapping>
    
    <welcome-file-list>
        <welcome-file>Home.jsp</welcome-file>
    </welcome-file-list>
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/teacher/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
</web-app>
